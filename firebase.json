{
  "database": {
    "rules": "database.rules.json"
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "site": "bt-training-firebase",
    "public": "public",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "/",
        "run": {
          "serviceId": "braintrade-training",
          "region": "asia-southeast1"
        }
      },
      {
        "source": "**",
        "run": {
          "serviceId": "braintrade-training",
          "region": "asia-southeast1"
        }
      }
    ]
  }
}
